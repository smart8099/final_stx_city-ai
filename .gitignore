.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ── Docker volumes (if mounted locally) ──────────────────────────────────────
postgres_data/
redis_data/

# ── Misc generated artefacts ─────────────────────────────────────────────────
*.pdf
