# =============================================================
# CityAssist monorepo .gitignore
# =============================================================
.claude/
#CLAUDE.md
*/CLAUDE.md
#.mcp.json
generate_architecture_pdf.py

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
!.env.local.example
# dashboard/.env.local is a symlink to ../.env created by `make env-setup`
dashboard/.env.local
*.pem
*.key
*.p12

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/

# Virtual environments
.venv/
venv/
.uv/

# ── Backend (static) ───────────────────────────────────────────────────────
backend/app/static/*.html

# Build / dist artefacts
backend/build/
backend/dist/
gradio_app/build/
gradio_app/dist/

# ── Python tooling caches ────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.lcov
.mypy_cache/
.ruff_cache/
.black_cache/

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/
/build
dashboard/.next/
dashboard/out/
dashboard/build/
web/.next/
web/out/
next-env.d.ts
*.tsbuildinfo

# ── Vite / widget build output ────────────────────────────────────────────────
# widget/dist/ is rebuilt by `make widget-copy` and committed to backend/app/static/
widget/dist/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

