# =============================================================
# CityAssist — single root .env (source of truth for all services)
# Copy to .env and fill in real values, then run: make env-setup
# =============================================================

# ── Infrastructure (docker-compose) ──────────────────────────────────────────
POSTGRES_USER=cityassist
POSTGRES_PASSWORD=cityassist
POSTGRES_DB=cityassist
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cityassist:cityassist@localhost:5432/cityassist
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one provider: "groq" | "openrouter"
# Fill in the API key for the chosen provider; the other can be left blank.
#
# ┌─ Groq (default) ────────────────────────────────────────────────────────┐
# │  Fast inference, free tier available. Sign up at console.groq.com       │
# │  LLM_PROVIDER=groq                                                      │
# │  GROQ_API_KEY=gsk_...                                                   │
# │  LLM_MODEL=llama-3.1-8b-instant          (dev)                         │
# │  ROUTING_MODEL=llama-3.3-70b-versatile   (prod routing)                │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─ OpenRouter ────────────────────────────────────────────────────────────┐
# │  Unified API across many models. Sign up at openrouter.ai               │
# │  Free-tier models end in :free (rate-limited but $0 cost)               │
# │  LLM_PROVIDER=openrouter                                                │
# │  OPENROUTER_API_KEY=sk-or-...                                           │
# │  LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free                      │
# │  ROUTING_MODEL=meta-llama/llama-3.3-70b-instruct:free                  │
# │  Other model options:                                                   │
# │    openai/gpt-4o-mini                                                   │
# │    meta-llama/llama-3.1-8b-instruct:free                               │
# └─────────────────────────────────────────────────────────────────────────┘

LLM_PROVIDER=groq
GROQ_API_KEY=gsk_
OPENROUTER_API_KEY=sk-or-

LLM_MODEL=llama-3.1-8b-instant
ROUTING_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ── LLM rate-limit / backoff ──────────────────────────────────────────────────
# Alert when remaining tokens drop below this fraction of quota (0.10 = 10 %)
# Note: token budget tracking only applies to Groq (other providers skip this)
RATE_LIMIT_ALERT_THRESHOLD=0.10
BACKOFF_MULTIPLIER=1.0
BACKOFF_MIN_WAIT=2.0
BACKOFF_MAX_WAIT=60.0
BACKOFF_MAX_ATTEMPTS=4

# ── SMTP / admin alerts ───────────────────────────────────────────────────────
# Leave ADMIN_EMAIL empty to disable email alerts entirely
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
ALERT_FROM_EMAIL=alerts@cityassist.io
ADMIN_EMAIL=admin@yourcity.gov

TAVILY_API_KEY=tvly-

APP_ENV=development
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7860

# ── Dashboard (Clerk) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Gradio ────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
TENANTS=City of Demo:demo-api-key-1
